  <div class="sd-stats"><div class="sd-sb"><div class="sd-sn">${eps.length}</div><div class="sd-sl">Total</div></div><div class="sd-sb"><div class="sd-sn" style="color:var(--pdmr)">${live}</div><div class="sd-sl">Live</div></div><div class="sd-sb"><div class="sd-sn" style="color:var(--fcko)">${eps.filter(e=>e.stage!=='Live'&&e.stage!=='Idea').length}</div><div class="sd-sl">In Prod</div></div><div class="sd-sb"><div class="sd-sn" style="color:var(--mu2)">${eps.filter(e=>e.stage==='Idea').length}</div><div class="sd-sl">Ideas</div></div></div>
