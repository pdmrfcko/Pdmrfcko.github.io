<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PDMR HQ</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box;}
:root{
  --bg:#090909;--sf:#0f0f0f;--s2:#151515;--s3:#1a1a1a;
  --br:#1e1e1e;--br2:#2a2a2a;
  --tx:#e2e2da;--mu:#484848;--mu2:#686868;
  --pdmr:#c8f542;--fcko:#ff6b35;--uco:#9b7fd4;--pha:#00d4aa;--pj:#f0c040;
}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);color:var(--tx);font-family:'DM Sans',sans-serif;font-size:13px;display:flex;flex-direction:column;}

/* TOPBAR */
.tb{display:flex;align-items:center;padding:0 18px;border-bottom:1px solid var(--br);flex-shrink:0;background:var(--bg);z-index:20;overflow-x:auto;}
.logo{font-family:'Bebas Neue',sans-serif;font-size:20px;margin-right:16px;padding:11px 0;flex-shrink:0;letter-spacing:.02em;}
.logo span{color:var(--pdmr);}
.nt{font-family:'Space Mono',monospace;font-size:7.5px;letter-spacing:.12em;text-transform:uppercase;padding:8px 10px 12px;cursor:pointer;color:var(--mu2);border-bottom:2px solid transparent;margin-bottom:-1px;transition:color .16s,border-color .16s;white-space:nowrap;user-select:none;flex-shrink:0;}
.nt:hover{color:var(--tx);}
.nt.a0{border-color:var(--mu2);color:var(--tx);}
.nt.a1{border-color:var(--pdmr);color:var(--pdmr);}
.nt.a2{border-color:var(--fcko);color:var(--fcko);}
.nt.a3{border-color:var(--uco);color:var(--uco);}
.nt.a4{border-color:var(--pha);color:var(--pha);}
.nt.a5{border-color:var(--pj);color:var(--pj);}
.tbr{margin-left:auto;display:flex;gap:7px;align-items:center;padding-left:10px;flex-shrink:0;}
.ai-btn{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.09em;text-transform:uppercase;padding:4px 10px;border:1px solid var(--pdmr);border-radius:2px;background:rgba(200,245,66,.06);color:var(--pdmr);cursor:pointer;transition:all .15s;white-space:nowrap;}
.ai-btn:hover{background:rgba(200,245,66,.13);}
.sb-toggle{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.09em;text-transform:uppercase;padding:4px 10px;border:1px solid var(--br2);border-radius:2px;background:none;color:var(--mu2);cursor:pointer;transition:all .15s;}
.sb-toggle:hover,.sb-toggle.on{border-color:var(--pdmr);color:var(--pdmr);}

/* LAYOUT */
.ws{display:flex;flex:1;overflow:hidden;}
.main{flex:1;overflow-y:auto;padding:18px 20px;}
.panel{display:none;animation:fi .18s ease;}
.panel.active{display:block;}
@keyframes fi{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:translateY(0)}}

/* SIDEBAR */
.sb{width:310px;border-left:1px solid var(--br);display:flex;flex-direction:column;background:var(--sf);overflow:hidden;transition:width .2s;flex-shrink:0;}
.sb.closed{width:0;border-left:none;}
.sb-hd{padding:11px 13px;border-bottom:1px solid var(--br);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.sb-ti{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.13em;text-transform:uppercase;color:var(--mu2);}
.sb-cl{background:none;border:none;color:var(--mu);cursor:pointer;font-size:13px;}
.sb-cl:hover{color:var(--tx);}
.sb-msgs{flex:1;overflow-y:auto;padding:11px 13px;display:flex;flex-direction:column;gap:8px;}
.m-ai{background:var(--s2);border:1px solid var(--br);border-radius:3px;padding:8px 10px;font-size:11px;line-height:1.6;}
.m-user{background:rgba(200,245,66,.06);border:1px solid rgba(200,245,66,.13);border-radius:3px;padding:8px 10px;font-size:11px;line-height:1.6;}
.m-th{color:var(--mu);font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.07em;animation:pl 1.4s infinite;}
@keyframes pl{0%,100%{opacity:1}50%{opacity:.22}}
.sb-inp{padding:9px 11px;border-top:1px solid var(--br);flex-shrink:0;}
.sb-inp textarea{width:100%;background:var(--s2);border:1px solid var(--br2);border-radius:2px;color:var(--tx);font-family:'DM Sans',sans-serif;font-size:11px;padding:6px 8px;outline:none;resize:none;height:58px;line-height:1.5;}
.sb-inp textarea:focus{border-color:var(--mu2);}
.sb-row{display:flex;justify-content:space-between;align-items:center;margin-top:5px;}
.sb-hint{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);}
.sb-snd{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.09em;text-transform:uppercase;padding:4px 10px;border:1px solid var(--pdmr);border-radius:2px;background:none;color:var(--pdmr);cursor:pointer;}
.sb-snd:disabled{opacity:.4;cursor:default;}
.qbs{display:flex;flex-wrap:wrap;gap:3px;margin-bottom:6px;}
.qb{font-family:'Space Mono',monospace;font-size:6.5px;padding:2px 6px;border:1px solid var(--br2);border-radius:2px;background:none;color:var(--mu2);cursor:pointer;letter-spacing:.04em;}
.qb:hover{border-color:var(--pdmr);color:var(--pdmr);}

/* GRIDS / CARDS */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
.g4{display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;}
.g5{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;}
.g1{display:grid;grid-template-columns:1fr;gap:10px;}
.wg{background:var(--sf);border:1px solid var(--br);border-radius:3px;padding:14px;}
.wg.sp2{grid-column:span 2;}
.wg.sp3{grid-column:span 3;}
.wg.sp4{grid-column:span 4;}
.wlbl{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);letter-spacing:.13em;text-transform:uppercase;margin-bottom:9px;display:flex;align-items:center;justify-content:space-between;}
.wlbl button{background:none;border:none;color:var(--mu);cursor:pointer;font-size:9px;transition:color .13s;}
.wlbl button:hover{color:var(--pdmr);}

/* HERO STATS */
.hero{background:var(--sf);border:1px solid var(--br);border-radius:3px;padding:14px 16px;position:relative;overflow:hidden;}
.hero::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.h-lbl{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);letter-spacing:.12em;text-transform:uppercase;margin-bottom:5px;}
.h-num{font-family:'Bebas Neue',sans-serif;font-size:32px;line-height:1;margin-bottom:2px;}
.h-sub{font-size:10px;color:var(--mu2);}

/* PERSONA CARDS */
.pgrid{display:grid;grid-template-columns:repeat(5,1fr);gap:9px;margin-bottom:12px;}
.pc{border:1px solid var(--br);border-radius:3px;padding:13px 11px;cursor:pointer;transition:transform .13s,border-color .16s;position:relative;overflow:hidden;}
.pc:hover{transform:translateY(-2px);}
.pc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.pc-pdmr{background:rgba(200,245,66,.05);}.pc-pdmr::before{background:var(--pdmr);}.pc-pdmr:hover{border-color:var(--pdmr);}
.pc-fcko{background:rgba(255,107,53,.05);}.pc-fcko::before{background:var(--fcko);}.pc-fcko:hover{border-color:var(--fcko);}
.pc-uco{background:rgba(155,127,212,.05);}.pc-uco::before{background:var(--uco);}.pc-uco:hover{border-color:var(--uco);}
.pc-pha{background:rgba(0,212,170,.05);}.pc-pha::before{background:var(--pha);}.pc-pha:hover{border-color:var(--pha);}
.pc-pj{background:rgba(240,192,64,.05);}.pc-pj::before{background:var(--pj);}.pc-pj:hover{border-color:var(--pj);}
.pcid{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);letter-spacing:.13em;text-transform:uppercase;margin-bottom:5px;}
.pcnm{font-family:'Bebas Neue',sans-serif;font-size:22px;line-height:1;margin-bottom:4px;}
.pcdesc{font-size:10px;color:var(--mu2);line-height:1.4;margin-bottom:8px;}
.sbadge{display:inline-flex;align-items:center;gap:4px;font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.08em;text-transform:uppercase;padding:2px 6px;border-radius:2px;background:rgba(255,255,255,.04);cursor:pointer;user-select:none;transition:transform .1s;}
.sbadge:hover{transform:scale(1.04);}
.dot{width:5px;height:5px;border-radius:50%;display:inline-block;flex-shrink:0;}
.pulse{animation:pl2 2s infinite;}
@keyframes pl2{0%,100%{opacity:1}50%{opacity:.18}}

/* PROGRESS */
.pr{display:flex;align-items:center;gap:7px;margin-bottom:6px;}
.prl{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu2);width:52px;flex-shrink:0;text-transform:uppercase;letter-spacing:.04em;}
.prb{flex:1;height:3px;background:var(--s3);border-radius:2px;overflow:hidden;}
.prf{height:100%;border-radius:2px;transition:width .5s ease;}
.prv{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);width:28px;text-align:right;}

/* TASKS / REMINDERS */
.trow{display:flex;align-items:center;gap:8px;padding:6px 0;border-bottom:1px solid var(--br);}
.trow:last-child{border-bottom:none;}
.tck{width:14px;height:14px;border:1px solid var(--mu);border-radius:2px;flex-shrink:0;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:8px;transition:all .14s;}
.tck.dn{background:var(--pdmr);border-color:var(--pdmr);color:#000;}
.ttx{flex:1;font-size:11px;}
.ttx.dn{color:var(--mu);text-decoration:line-through;}
.tptag{font-family:'Space Mono',monospace;font-size:7px;padding:2px 5px;border-radius:2px;border:1px solid;flex-shrink:0;}
.tdue{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);flex-shrink:0;}
.tdel,.rdel,.ep-del,.sc-del{background:none;border:none;color:var(--mu);cursor:pointer;font-size:9px;opacity:0;transition:opacity .13s;}
.trow:hover .tdel,.rrow:hover .rdel,.ep-card:hover .ep-del,.sc:hover .sc-del{opacity:1;}
.rrow{display:flex;align-items:flex-start;gap:7px;padding:6px 0;border-bottom:1px solid var(--br);}
.rrow:last-child{border-bottom:none;}
.rdot{width:7px;height:7px;border-radius:50%;flex-shrink:0;margin-top:3px;}
.rtx{flex:1;font-size:11px;line-height:1.4;}
.rtm{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);margin-top:1px;}

/* TOM */
.tom{display:flex;align-items:flex-start;gap:6px;padding:6px 0;border-bottom:1px solid var(--br);font-size:11px;color:var(--mu2);line-height:1.4;}
.tom:last-child{border-bottom:none;}
.tomn{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);width:14px;flex-shrink:0;padding-top:2px;}
.tomd{background:none;border:none;color:var(--mu);cursor:pointer;font-size:9px;margin-left:auto;opacity:0;flex-shrink:0;}
.tom:hover .tomd{opacity:1;}

/* STAT BOX */
.srow{display:flex;gap:7px;}
.sbox{flex:1;text-align:center;padding:8px 5px;background:var(--s2);border-radius:3px;}
.snum{font-family:'Bebas Neue',sans-serif;font-size:20px;}
.slbl{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);letter-spacing:.07em;text-transform:uppercase;}

/* HIER */
.hier{display:flex;align-items:center;flex-wrap:wrap;gap:0;margin-bottom:12px;}
.hs{background:var(--s2);border:1px solid var(--br);padding:5px 10px;font-family:'Space Mono',monospace;font-size:7.5px;letter-spacing:.07em;text-transform:uppercase;}
.ha{color:var(--mu);padding:0 4px;font-size:10px;}

/* INPUT */
.ir{display:flex;gap:5px;margin-top:6px;}
.ir input,.ir select,.fi{background:var(--s2);border:1px solid var(--br2);border-radius:2px;color:var(--tx);font-family:'DM Sans',sans-serif;font-size:11px;padding:5px 7px;outline:none;flex:1;}
.ir input:focus,.ir select:focus,.fi:focus{border-color:var(--mu2);}
.ir select option{background:var(--s2);}
.bsm{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.07em;text-transform:uppercase;padding:4px 9px;border:1px solid var(--br2);border-radius:2px;background:none;color:var(--mu2);cursor:pointer;transition:all .13s;white-space:nowrap;}
.bsm:hover,.bsm.ac{border-color:var(--pdmr);color:var(--pdmr);}
.addb{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.07em;text-transform:uppercase;padding:4px 8px;border:1px dashed var(--br2);border-radius:2px;background:none;color:var(--mu);cursor:pointer;margin-top:6px;transition:color .13s,border-color .13s;}
.addb:hover{color:var(--tx);border-color:var(--mu2);}

/* BACK */
.bk{display:inline-flex;align-items:center;gap:5px;font-family:'Space Mono',monospace;font-size:7.5px;letter-spacing:.09em;text-transform:uppercase;color:var(--mu);cursor:pointer;margin-bottom:14px;padding:4px 8px;border:1px solid var(--br);border-radius:2px;background:none;transition:color .13s,border-color .13s;}
.bk:hover{color:var(--tx);border-color:var(--mu2);}

/* DETAIL HEADER */
.dh{margin-bottom:16px;}
.dtag{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.13em;text-transform:uppercase;margin-bottom:4px;}
.dname{font-family:'Bebas Neue',sans-serif;font-size:48px;line-height:.9;margin-bottom:6px;}
.dsub{font-size:12px;color:var(--mu2);line-height:1.6;max-width:460px;}

/* TAG */
.tag{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.05em;padding:2px 7px;border-radius:2px;border:1px solid;display:inline-block;margin:2px;}

/* SERIES */
.sgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:9px;margin-bottom:14px;}
.sc{background:var(--sf);border:1px solid var(--br);border-radius:3px;padding:14px 13px;cursor:pointer;transition:transform .13s,border-color .16s;position:relative;overflow:hidden;}
.sc:hover{transform:translateY(-2px);}
.sc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.scid{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);letter-spacing:.12em;text-transform:uppercase;margin-bottom:5px;}
.scnm{font-family:'Bebas Neue',sans-serif;font-size:20px;line-height:1;margin-bottom:3px;}
.scdesc{font-size:10px;color:var(--mu2);line-height:1.4;margin-bottom:8px;}
.sc-stats{display:flex;gap:8px;}
.sc-sn{font-family:'Bebas Neue',sans-serif;font-size:18px;line-height:1;}
.sc-sl{font-family:'Space Mono',monospace;font-size:6px;color:var(--mu);letter-spacing:.06em;text-transform:uppercase;}
.sc-pb{margin-top:7px;height:2px;background:var(--br2);border-radius:2px;overflow:hidden;}
.sc-pf{height:100%;border-radius:2px;transition:width .5s ease;}
.sc-add{border:1px dashed var(--br2);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:6px;color:var(--mu);transition:color .13s,border-color .13s;min-height:100px;}
.sc-add:hover{color:var(--tx);border-color:var(--mu2);}
.sc-add-lbl{font-family:'Space Mono',monospace;font-size:8px;letter-spacing:.09em;text-transform:uppercase;}

/* SERIES DETAIL */
.sd-stats{display:flex;gap:9px;margin-bottom:16px;flex-wrap:wrap;}
.sd-sb{background:var(--s2);border:1px solid var(--br);border-radius:3px;padding:8px 12px;text-align:center;}
.sd-sn{font-family:'Bebas Neue',sans-serif;font-size:24px;}
.sd-sl{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);letter-spacing:.08em;text-transform:uppercase;}
.sd-desc{font-size:12px;color:var(--mu2);line-height:1.6;background:var(--s2);border:1px solid var(--br);border-radius:3px;padding:8px 10px;margin-bottom:14px;outline:none;width:100%;}

/* PROD STEPS */
.steps-ed{background:var(--sf);border:1px solid var(--br);border-radius:3px;padding:12px;margin-bottom:14px;}
.step-row{display:flex;align-items:flex-start;gap:7px;padding:7px 0;border-bottom:1px solid var(--br);}
.step-row:last-child{border-bottom:none;}
.step-drag{color:var(--mu);font-size:9px;cursor:grab;padding:2px 0;flex-shrink:0;}
.step-name{font-size:12px;font-weight:500;flex:1;outline:none;background:none;border:none;color:var(--tx);font-family:'DM Sans',sans-serif;}
.step-name:focus{border-bottom:1px solid var(--mu2);}
.step-tog{background:none;border:none;color:var(--mu2);cursor:pointer;font-size:8px;font-family:'Space Mono',monospace;letter-spacing:.05em;text-transform:uppercase;transition:color .13s;}
.step-tog:hover{color:var(--tx);}
.step-del2{background:none;border:none;color:var(--mu);cursor:pointer;font-size:9px;opacity:0;transition:opacity .13s;flex-shrink:0;}
.step-row:hover .step-del2{opacity:1;}
.substeps{padding-left:18px;margin-top:4px;flex-direction:column;gap:3px;display:none;}
.ssr{display:flex;align-items:center;gap:5px;}
.ssn{font-size:11px;color:var(--mu2);outline:none;background:none;border:none;font-family:'DM Sans',sans-serif;flex:1;}
.ssn:focus{border-bottom:1px solid var(--mu);}
.ssd{background:none;border:none;color:var(--mu);cursor:pointer;font-size:8px;opacity:0;}
.ssr:hover .ssd{opacity:1;}
.add-ss{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.06em;text-transform:uppercase;color:var(--mu);background:none;border:none;cursor:pointer;padding:2px 0 2px 18px;}
.add-ss:hover{color:var(--tx);}

/* EPISODE BOARD */
.ep-board{display:flex;gap:8px;overflow-x:auto;padding-bottom:7px;}
.ep-col{flex-shrink:0;width:170px;background:var(--s2);border:1px solid var(--br);border-radius:3px;display:flex;flex-direction:column;}
.ep-ch{padding:8px 9px;border-bottom:1px solid var(--br);display:flex;align-items:center;justify-content:space-between;}
.ep-ct{font-family:'Space Mono',monospace;font-size:7.5px;letter-spacing:.09em;text-transform:uppercase;color:var(--mu2);}
.ep-cc{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);background:var(--s3);padding:1px 5px;border-radius:9px;}
.ep-cb{padding:6px;display:flex;flex-direction:column;gap:4px;min-height:44px;}
.ep-card{background:var(--sf);border:1px solid var(--br);border-radius:3px;padding:8px;cursor:pointer;transition:border-color .13s;position:relative;}
.ep-card:hover{border-color:var(--mu2);}
.ep-num{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);margin-bottom:2px;}
.ep-etitle{font-size:11px;line-height:1.3;margin-bottom:4px;}
.ep-emeta{display:flex;flex-wrap:wrap;gap:3px;}
.ep-etag{font-family:'Space Mono',monospace;font-size:6.5px;padding:1px 5px;border-radius:2px;border:1px solid var(--mu);color:var(--mu2);}
.ep-add{margin:4px 6px 6px;padding:5px;border:1px dashed var(--br2);border-radius:2px;background:none;color:var(--mu);font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.06em;cursor:pointer;text-align:center;}
.ep-add:hover{color:var(--tx);border-color:var(--mu2);}

/* PLATFORM TRACKER */
.plt-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));gap:8px;}
.plt-card{background:var(--s2);border:1px solid var(--br);border-radius:3px;padding:11px;position:relative;}
.plt-icon{font-size:18px;margin-bottom:5px;}
.plt-name{font-size:12px;font-weight:500;margin-bottom:2px;}
.plt-handle{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu2);margin-bottom:6px;}
.plt-status{font-family:'Space Mono',monospace;font-size:7px;padding:2px 7px;border-radius:2px;border:1px solid;cursor:pointer;user-select:none;}
.plt-add{border:1px dashed var(--br2);cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;color:var(--mu);transition:color .13s,border-color .13s;min-height:75px;border-radius:3px;}
.plt-add:hover{color:var(--tx);border-color:var(--mu2);}
.plt-del{position:absolute;top:6px;right:6px;background:none;border:none;color:var(--mu);cursor:pointer;font-size:9px;opacity:0;}
.plt-card:hover .plt-del{opacity:1;}

/* ANALYTICS */
.al-row{display:flex;align-items:center;gap:9px;padding:7px 0;border-bottom:1px solid var(--br);cursor:pointer;}
.al-row:last-child{border-bottom:none;}
.al-row:hover{background:var(--s2);margin:0 -14px;padding:7px 14px;}
.ar-rank{font-family:'Space Mono',monospace;font-size:7.5px;color:var(--mu);width:16px;flex-shrink:0;}
.ar-title{flex:1;font-size:11px;line-height:1.3;}
.ar-sub{font-size:9px;color:var(--mu2);margin-top:1px;}
.ar-tag{font-family:'Space Mono',monospace;font-size:7px;padding:2px 5px;border-radius:2px;border:1px solid;flex-shrink:0;}
.ar-stat{font-family:'Bebas Neue',sans-serif;font-size:15px;flex-shrink:0;min-width:36px;text-align:right;}
.ar-bw{width:50px;flex-shrink:0;}
.ar-b{height:3px;background:var(--br2);border-radius:2px;overflow:hidden;}
.ar-f{height:100%;border-radius:2px;}

/* HASHTAG CLOUD */
.htag-cloud{display:flex;flex-wrap:wrap;gap:5px;}
.htag{font-family:'Space Mono',monospace;letter-spacing:.04em;padding:3px 8px;border-radius:2px;border:1px solid;cursor:default;transition:transform .1s;}
.htag:hover{transform:scale(1.04);}

/* LOG TABLE */
.log-tbl{width:100%;border-collapse:collapse;font-size:11px;}
.log-tbl th{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);letter-spacing:.09em;text-transform:uppercase;padding:0 0 8px;border-bottom:1px solid var(--br);text-align:left;}
.log-tbl td{padding:7px 0;border-bottom:1px solid rgba(30,30,30,.6);vertical-align:middle;}
.log-tbl tr:last-child td{border-bottom:none;}
.log-tbl .num{font-family:'Space Mono',monospace;font-size:9px;}

/* AI INSIGHT */
.ins-panel{background:var(--s2);border:1px solid var(--br2);border-radius:3px;padding:14px;min-height:100px;}
.ins-msg{font-size:12px;line-height:1.7;}
.ins-msg strong{color:var(--pdmr);}
.ins-msg .itag{display:inline-block;font-family:'Space Mono',monospace;font-size:7.5px;padding:1px 5px;border:1px solid var(--pdmr);border-radius:2px;color:var(--pdmr);margin:1px;}
.ins-input{background:var(--s2);border:1px solid var(--br2);border-radius:2px;color:var(--tx);font-family:'DM Sans',sans-serif;font-size:11px;padding:6px 9px;outline:none;flex:1;}
.ins-input:focus{border-color:var(--mu2);}
.ins-btn{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.09em;text-transform:uppercase;padding:6px 12px;border:1px solid var(--pdmr);border-radius:2px;background:rgba(200,245,66,.06);color:var(--pdmr);cursor:pointer;white-space:nowrap;}
.ins-btn:hover{background:rgba(200,245,66,.13);}
.ins-btn:disabled{opacity:.4;cursor:default;}
.qas{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:8px;}
.qa{font-family:'Space Mono',monospace;font-size:7px;padding:2px 7px;border:1px solid var(--br2);border-radius:2px;background:none;color:var(--mu2);cursor:pointer;letter-spacing:.04em;}
.qa:hover{border-color:var(--pdmr);color:var(--pdmr);}

/* API SLOTS */
.api-row{margin-bottom:9px;}
.api-row .api-inp-row{display:flex;gap:5px;margin-top:4px;}
.api-inp-row input{background:var(--s2);border:1px solid var(--br2);border-radius:2px;color:var(--tx);font-family:'Space Mono',monospace;font-size:8px;padding:4px 7px;outline:none;flex:1;letter-spacing:.04em;}
.api-inp-row input:focus{border-color:var(--mu2);}
.api-inp-row button{font-family:'Space Mono',monospace;font-size:7px;padding:4px 8px;border:1px solid var(--pdmr);border-radius:2px;background:rgba(200,245,66,.06);color:var(--pdmr);cursor:pointer;white-space:nowrap;}

/* ARCH */
.dvgrid{display:grid;grid-template-columns:repeat(5,1fr);gap:7px;}
.dvc{background:var(--s2);border:1px solid var(--br);border-radius:3px;padding:10px 8px;text-align:center;}
.dvi{font-size:15px;margin-bottom:5px;}
.dvn{font-family:'Space Mono',monospace;font-size:8px;font-weight:700;margin-bottom:2px;letter-spacing:.04em;}
.dvr{font-size:9px;color:var(--mu);}
.ptbl{width:100%;border-collapse:collapse;font-family:'Space Mono',monospace;font-size:9px;}
.ptbl th{text-align:left;color:var(--mu);padding:0 0 7px;border-bottom:1px solid var(--br);letter-spacing:.08em;text-transform:uppercase;font-size:8px;}
.ptbl td{padding:7px 0;border-bottom:1px solid rgba(30,30,30,.6);vertical-align:middle;}

/* CHART */
.ch-wrap{position:relative;height:170px;}
.ch-wrap.tall{height:220px;}

/* SECTION HEAD */
.sh{font-family:'Bebas Neue',sans-serif;font-size:17px;color:var(--mu2);letter-spacing:.05em;margin-bottom:9px;}

/* MODAL */
.mo{position:fixed;inset:0;background:rgba(0,0,0,.74);z-index:100;display:flex;align-items:center;justify-content:center;}
.mo.hi{display:none;}
.mw{background:var(--sf);border:1px solid var(--br2);border-radius:4px;width:500px;max-width:95vw;max-height:88vh;overflow-y:auto;padding:20px;}
.mhd{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;}
.mtitle{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:.02em;}
.mcl{background:none;border:none;color:var(--mu2);font-size:14px;cursor:pointer;}
.mcl:hover{color:var(--tx);}
.mf{margin-bottom:10px;}
.ml{font-family:'Space Mono',monospace;font-size:7px;color:var(--mu);letter-spacing:.12em;text-transform:uppercase;margin-bottom:3px;}
.mi{width:100%;background:var(--s2);border:1px solid var(--br2);border-radius:2px;color:var(--tx);font-family:'DM Sans',sans-serif;font-size:12px;padding:5px 8px;outline:none;}
.mi:focus{border-color:var(--mu2);}
.mi.ta{resize:vertical;min-height:60px;line-height:1.5;}
.mr2{display:flex;gap:6px;}
.mr2 .mf{flex:1;}
.ms{width:100%;background:var(--s2);border:1px solid var(--br2);border-radius:2px;color:var(--tx);font-family:'DM Sans',sans-serif;font-size:12px;padding:5px 8px;outline:none;}
.ms option{background:var(--s2);}
.mbt{display:flex;gap:6px;justify-content:flex-end;margin-top:13px;}
.mb{font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.09em;text-transform:uppercase;padding:5px 12px;border-radius:2px;cursor:pointer;transition:all .13s;}
.mb.cn{background:none;border:1px solid var(--br2);color:var(--mu2);}
.mb.cn:hover{color:var(--tx);}
.mb.sv{background:var(--pdmr);border:1px solid var(--pdmr);color:#000;font-weight:700;}
.mb.sv:hover{opacity:.86;}
.tp{width:100%;height:75px;object-fit:cover;border-radius:2px;border:1px solid var(--br);margin-top:4px;display:none;}
.tp.sh2{display:block;}

/* SAVE FLASH */
.sfl{position:fixed;bottom:14px;right:14px;font-family:'Space Mono',monospace;font-size:7px;letter-spacing:.1em;text-transform:uppercase;color:var(--pdmr);border:1px solid var(--pdmr);padding:5px 10px;border-radius:2px;background:var(--bg);opacity:0;transition:opacity .25s;pointer-events:none;z-index:999;}
.sfl.show{opacity:1;}
::-webkit-scrollbar{width:3px;height:3px;}
::-webkit-scrollbar-thumb{background:var(--br2);border-radius:2px;}
.hi2{display:none!important;}
hr.sep{border:none;border-top:1px solid var(--br);margin:11px 0;}
</style>
</head>
