async function askAI(q){
  const inp=document.getElementById('ins-inp');const question=q||inp.value.trim();
  if(!question)return;inp.value='';
  const btn=document.getElementById('ins-btn');btn.disabled=true;
  document.getElementById('ins-panel').innerHTML='<div class="m-th">Analyzing your data...</div>';
  const st=computeStats();const bp=byP();const pl=byPlat();const ht=htFreq();
  const topTags=Object.entries(ht).sort((a,b)=>b[1].totalViews-a[1].totalViews).slice(0,10);
  const topHooks=analyticsLog.filter(e=>e.hook).sort((a,b)=>(b.views||0)-(a.views||0)).slice(0,5);
  const recent=[...analyticsLog].sort((a,b)=>new Date(b.date||0)-new Date(a.date||0)).slice(0,10);
  const ctx=`ANALYTICS: views=${fmt(st.views)}, eng=${fmt(st.eng)}, followers=${fmt(st.followers)}, posts=${st.count}, avgScore=${st.avgScore.toFixed(1)}
BY PERSONA: ${Object.entries(bp).map(([p,d])=>`${p}: ${fmt(d.views)}views/${fmt(d.eng)}eng/${d.count}posts`).join(', ')}
BY PLATFORM: ${Object.entries(pl).map(([p,d])=>`${p}: ${fmt(d.views)}views/${d.count}posts`).join(', ')}
TOP HASHTAGS: ${topTags.map(([t,d])=>`${t}(${d.count}uses/${fmt(d.totalViews)}views)`).join(', ')}
TOP HOOKS: ${topHooks.map(e=>`"${e.hook}"→${fmt(e.views||0)}views`).join(' | ')}
RECENT: ${recent.map(e=>`"${e.title}"(${e.persona}/${e.platform}/${e.type},${fmt(e.views||0)}views,score:${e.score||'?'},tags:${e.hashtags||'none'})`).join(' | ')}`;
  const sys=`You are a sharp, direct content intelligence analyst for PDMR — a multidisciplinary creative with 5 personas: PDMR (artist/designer/producer), FCKO (content studio), UCO (creative agency), P.H.A Love (secret music, clinical sound design), P.JUXT (personal layer). Analyze the data and give actionable, specific, honest insights. Be direct and conversational. Use concrete numbers. When recommending hashtags explain WHY based on performance. Format with bold key points. Max 220 words.`;
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:500,system:sys,messages:[{role:'user',content:ctx+'\n\nQuestion: '+question}]})});
    const data=await r.json();const text=data.content?.[0]?.text||'No response.';
    const fmt2=text.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/#(\w+)/g,'<span class="itag">#$1</span>').replace(/\n\n/g,'</p><p>').replace(/\n/g,'<br>');
    document.getElementById('ins-panel').innerHTML=`<div class="ins-msg"><p>${fmt2}</p></div>`;
    document.getElementById('reco-intel').innerHTML=`<div style="font-size:10px;color:var(--mu2);margin-bottom:5px;font-style:italic">Based on: "${question}"</div><div style="font-size:11px;line-height:1.7;">${fmt2}</div>`;
  }catch(e){document.getElementById('ins-panel').innerHTML='<div class="m-th">Run from claude.ai for AI Intelligence to work.</div>';}
  btn.disabled=false;
}

