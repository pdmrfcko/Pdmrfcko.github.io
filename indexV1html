  inp.value='';const btn=document.getElementById('sb-btn');btn.disabled=true;
  addSBMsg(prompt,'user');const th=addSBMsg('thinking...','th');
  const sys=`You are an AI dashboard builder for PDMR HQ. Panels: command, analytics, intelligence, tasks, reminders, series, content, pdmr, fcko, uco, pha, pj, arch. Extra widgets go in #extra-{panel} or #extra-{persona} divs. CSS vars: --pdmr:#c8f542, --fcko:#ff6b35, --uco:#9b7fd4, --pha:#00d4aa, --pj:#f0c040, --bg:#090909, --sf:#0f0f0f, --s2:#151515, --br:#1e1e1e, --tx:#e2e2da, --mu:#484848, --mu2:#686868. Classes: .wg (card), .wlbl (label), .g2/.g3/.g4 (grids). Respond with brief confirmation then: {"action":"inject","target":"extra-overview","html":"..."} or {"action":"js","code":"..."}. Short responses only.`;
  try{
    const r=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:900,system:sys,messages:[{role:'user',content:prompt}]})});
    const data=await r.json();const raw=data.content?.[0]?.text||'Something went wrong.';
    th.remove();const jm=raw.match(/\{[\s\S]*?"action"[\s\S]*?\}/);let disp=raw;
    if(jm){try{const act=JSON.parse(jm[0]);disp=raw.replace(jm[0],'').replace(/```json|```/g,'').trim();if(act.action==='inject'&&act.target&&act.html){const tgt=document.getElementById(act.target);if(tgt){const w=document.createElement('div');w.innerHTML=act.html;tgt.appendChild(w);sched();}}else if(act.action==='js'&&act.code){try{eval(act.code);sched();}catch(e){}}}catch(e){}}
    addSBMsg(disp||'Done ✓','ai');
  }catch(e){th.remove();addSBMsg('Run from claude.ai for AI Builder to work.','ai');}
  btn.disabled=false;
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━
//  SAVE / LOAD
// ━━━━━━━━━━━━━━━━━━━━━━━━━━
function sched(){clearTimeout(saveTimer);saveTimer=setTimeout(doSave,900);}
function doSave(){
  try{
    localStorage.setItem('hq_main',document.getElementById('mainArea').innerHTML);
    localStorage.setItem('hq_series',JSON.stringify(seriesList));
    localStorage.setItem('hq_eps',JSON.stringify(episodes));
    localStorage.setItem('hq_plts',JSON.stringify(platforms));
    localStorage.setItem('hq_vids',JSON.stringify(videos));
    localStorage.setItem('hq_analytics',JSON.stringify(analyticsLog));
    flash();
  }catch(e){}
}
function flash(){const el=document.getElementById('sfl');el.classList.add('show');setTimeout(()=>el.classList.remove('show'),1400);}
function loadSaved(){
  try{
    const m=localStorage.getItem('hq_main');if(m)document.getElementById('mainArea').innerHTML=m;
    const s=localStorage.getItem('hq_series');if(s)seriesList=JSON.parse(s);
    const ep=localStorage.getItem('hq_eps');if(ep)episodes=JSON.parse(ep);
    const pl=localStorage.getItem('hq_plts');if(pl)platforms=JSON.parse(pl);
    const v=localStorage.getItem('hq_vids');if(v)videos=JSON.parse(v);
    const a=localStorage.getItem('hq_analytics');if(a)analyticsLog=JSON.parse(a);
    renderSeriesGrid();renderVids();renderCommand();
  }catch(e){}
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━
//  INIT
// ━━━━━━━━━━━━━━━━━━━━━━━━━━
document.addEventListener('input',e=>{if(e.target.contentEditable==='true')sched();});
document.querySelector('[data-tab="command"]').classList.add('a0');
loadSaved();
updDone();
</script>
</body>
