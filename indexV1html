function saveSeries(){
  const name=document.getElementById('sf-name').value.trim();if(!name){document.getElementById('sf-name').focus();return;}
  const editId=document.getElementById('sf-id').value;
  const rawSteps=document.getElementById('sf-steps').value;
  let steps;
  if(editId){const existing=seriesList.find(x=>x.id===editId);steps=existing?existing.steps:buildSteps(rawSteps);const nn=rawSteps.split(',').map(s=>s.trim()).filter(Boolean);const en=(steps||[]).map(s=>s.name);nn.forEach(n=>{if(!en.includes(n))steps.push({name:n,substeps:[]});});}
  else steps=buildSteps(rawSteps);
  const entry={id:editId||('s'+Date.now()),name,persona:document.getElementById('sf-p').value,platforms:document.getElementById('sf-plats').value.trim(),format:document.getElementById('sf-fmt').value.trim(),status:document.getElementById('sf-status').value,desc:document.getElementById('sf-desc').value.trim(),steps};
  if(editId){const i=seriesList.findIndex(x=>x.id===editId);if(i>-1)seriesList[i]=entry;}
