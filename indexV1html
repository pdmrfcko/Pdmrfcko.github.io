function buildSteps(raw){
  const names=raw.split(',').map(s=>s.trim()).filter(Boolean);
  return names.map(n=>{const def=DEFAULT_STEPS.find(d=>d.name.toLowerCase()===n.toLowerCase());return{name:n,substeps:def?[...def.substeps]:[]};});
}

