function addPlt(persona){
  const name=prompt('Platform name:');if(!name)return;
  const handle=prompt('Handle / URL (optional):')||'';
  const icon=prompt('Emoji icon (optional):')||'🌐';
  if(!platforms[persona])platforms[persona]=[];
  platforms[persona].push({id:'plt'+Date.now(),name,handle,icon,status:'Setting Up'});
  renderPersona(persona);sched();
}
const PLT_SC={Active:'var(--pdmr)','Setting Up':'var(--uco)',Planned:'var(--mu2)','On Hold':'var(--mu)'};
function cyclePlt(persona,id,el){
  const plt=(platforms[persona]||[]).find(x=>x.id===id);if(!plt)return;
  const i=PLT_STATUSES.indexOf(plt.status);plt.status=PLT_STATUSES[(i+1)%PLT_STATUSES.length];
  const c=PLT_SC[plt.status]||'var(--mu)';el.textContent=plt.status;el.style.color=c;el.style.borderColor=c;sched();
}
function delPlt(persona,id){if(!platforms[persona])return;platforms[persona]=platforms[persona].filter(x=>x.id!==id);renderPersona(persona);sched();}

