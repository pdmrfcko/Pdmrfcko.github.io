<script>
// ━━━━━━━━━━━━━━━━━━━━━━━━━━
//  CONSTANTS
// ━━━━━━━━━━━━━━━━━━━━━━━━━━
const PCOL={pdmr:'#c8f542',fcko:'#ff6b35',uco:'#9b7fd4',pha:'#00d4aa',pj:'#f0c040'};
const PNAMES={pdmr:'PDMR',fcko:'FCKO',uco:'UCO',pha:'P.H.A',pj:'P.JUXT'};
const PDESCS={pdmr:'Artist · Designer · Producer',fcko:'Content Studio',uco:'Creative Agency',pha:'Clinical Sound Design',pj:'Personal · PKM · Growth'};
const PNUMS={pdmr:'01 · External',fcko:'02 · External',uco:'03 · External',pha:'04 · Internal / Secret',pj:'05 · Internal / Personal'};
const PPARA={
  pdmr:'Multidisciplinary artist, designer, and media producer. Central professional interface managing freelance work and publishing.',
  fcko:'Content-first creative studio managing the full production pipeline across all media formats.',
  uco:'Unorthodox Co — disruptive creative studio providing brand, development, and production services.',
  pha:'Secret music persona. Clinical sound design rooted in occult frequencies — sound as physical feeling.',
  pj:'Psychonautic Juxtaposition — foundational personal layer. Growth, school, PKM, herbalism, fitness, Python, frequencies.'
};
const STATUSES=['Active','Building','Refining','In Dev','On Hold','Done','Base Layer'];
const SCOL={Active:'#c8f542',Building:'#ff6b35',Refining:'#9b7fd4','In Dev':'#00d4aa','On Hold':'#484848','Done':'#686868','Base Layer':'#f0c040'};
const TAB_CLS={command:'a0',analytics:'a0',intelligence:'a0',tasks:'a0',reminders:'a0',series:'a0',content:'a0',pdmr:'a1',fcko:'a2',uco:'a3',pha:'a4',pj:'a5',arch:'a0'};
const DEFAULT_STEPS=[
  {name:'Idea',substeps:['Concept brainstorm','Angle/hook','Feasibility check']},
  {name:'Script',substeps:['Research','Rough draft','Final draft','Review']},
  {name:'Record',substeps:['Setup & gear check','Record session','Backup files']},
  {name:'Edit',substeps:['Assembly cut','Fine cut','Color/audio grade','Thumbnail']},
  {name:'Review',substeps:['Self review','Peer review','Final sign-off']},
  {name:'Publish',substeps:['Upload','SEO/metadata','Schedule']},
  {name:'Live',substeps:['Posted','Analytics check']}
];
const PLT_STATUSES=['Active','Setting Up','Planned','On Hold'];
const VSTAGES=['Idea','Script','Record','Edit','Review','Publish','Live'];

// ━━━━━━━━━━━━━━━━━━━━━━━━━━
//  STATE
// ━━━━━━━━━━━━━━━━━━━━━━━━━━
let seriesList=[], episodes={}, platforms={}, videos=[], analyticsLog=[];
let currentSeries=null, vpFilter='all', sbOpen=false, saveTimer=null;
let charts={};

// ━━━━━━━━━━━━━━━━━━━━━━━━━━
//  NAV
// ━━━━━━━━━━━━━━━━━━━━━━━━━━
function goTab(name,el){
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nt').forEach(t=>{t.className='nt';});
  document.getElementById('panel-'+name)?.classList.add('active');
  const tab=el||document.querySelector('[data-tab="'+name+'"]');
  if(tab) tab.classList.add(TAB_CLS[name]||'a0');
  if(['pdmr','fcko','uco','pha','pj'].includes(name)) renderPersona(name);
  if(name==='analytics') renderAnalytics();
  if(name==='intelligence') renderIntelligence();
  if(name==='command') renderCommand();
  window.scrollTo({top:0});
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━
//  ANALYTICS COMPUTE
// ━━━━━━━━━━━━━━━━━━━━━━━━━━
function tot(k){return analyticsLog.reduce((s,e)=>s+(parseFloat(e[k])||0),0);}
function computeStats(){
  const sc=analyticsLog.filter(e=>e.score);
  return{views:tot('views'),likes:tot('likes'),comments:tot('comments'),shares:tot('shares'),followers:tot('followers'),
    eng:tot('likes')+tot('comments')+tot('shares'),count:analyticsLog.length,
    avgScore:sc.length?sc.reduce((s,e)=>s+(parseFloat(e.score)||0),0)/sc.length:0};
}
function byP(){const r={};analyticsLog.forEach(e=>{if(!r[e.persona])r[e.persona]={views:0,eng:0,count:0,followers:0};r[e.persona].views+=parseFloat(e.views)||0;r[e.persona].eng+=(parseFloat(e.likes)||0)+(parseFloat(e.comments)||0)+(parseFloat(e.shares)||0);r[e.persona].count++;r[e.persona].followers+=parseFloat(e.followers)||0;});return r;}
function byPlat(){const r={};analyticsLog.forEach(e=>{if(!r[e.platform])r[e.platform]={views:0,eng:0,count:0};r[e.platform].views+=parseFloat(e.views)||0;r[e.platform].eng+=(parseFloat(e.likes)||0)+(parseFloat(e.comments)||0)+(parseFloat(e.shares)||0);r[e.platform].count++;});return r;}
function htFreq(){const r={};analyticsLog.forEach(e=>{if(!e.hashtags)return;(e.hashtags.match(/#\w+/g)||[]).forEach(t=>{const tl=t.toLowerCase();if(!r[tl])r[tl]={count:0,totalViews:0,totalEng:0};r[tl].count++;r[tl].totalViews+=parseFloat(e.views)||0;r[tl].totalEng+=(parseFloat(e.likes)||0)+(parseFloat(e.comments)||0)+(parseFloat(e.shares)||0);});});return r;}
function bySer(){const r={};analyticsLog.forEach(e=>{if(!e.series)return;if(!r[e.series])r[e.series]={views:0,eng:0,count:0};r[e.series].views+=parseFloat(e.views)||0;r[e.series].eng+=(parseFloat(e.likes)||0)+(parseFloat(e.comments)||0)+(parseFloat(e.shares)||0);r[e.series].count++;});return r;}
function fmt(n){if(n>=1e6)return(n/1e6).toFixed(1)+'M';if(n>=1000)return(n/1000).toFixed(1)+'K';return Math.round(n).toString();}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━
//  COMMAND PANEL
// ━━━━━━━━━━━━━━━━━━━━━━━━━━
function renderCommand(){
  const st=computeStats();
  document.getElementById('hv').textContent=st.count?fmt(st.views):'—';
  document.getElementById('he').textContent=st.count?fmt(st.eng):'—';
  document.getElementById('hf').textContent=st.count?fmt(st.followers):'—';
  document.getElementById('hc').textContent=st.count||'—';
  document.getElementById('hs').textContent=st.avgScore?st.avgScore.toFixed(1):'—';
  const bp=byP();
  ['pdmr','fcko','uco','pha','pj'].forEach(p=>{
    const d=bp[p]||{views:0,eng:0,count:0};
    const el=document.getElementById('cmd-'+p+'-stats');
