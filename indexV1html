function openEpMo(defaultStage,editId,sid){
  const s=seriesList.find(x=>x.id===sid);const eps=episodes[sid]||[];const ep=editId?eps.find(x=>x.id===editId):null;
  const nextNum=eps.length?Math.max(...eps.map(e=>parseInt(e.num)||0))+1:1;
  const stg=document.getElementById('ef-stage');stg.innerHTML='';
  const stages=s&&s.steps?s.steps.map(st=>st.name):DEFAULT_STEPS.map(st=>st.name);
  stages.forEach(st=>{const o=document.createElement('option');o.value=st;o.textContent=st;stg.appendChild(o);});
  document.getElementById('ef-num').value=ep?(ep.num||''):nextNum;
  document.getElementById('ef-title').value=ep?ep.title:'';
  stg.value=ep?ep.stage:(defaultStage||stages[0]);
  document.getElementById('ef-plats').value=ep?(ep.platforms||''):'';
  document.getElementById('ef-rec').value=ep?(ep.record||''):'';
  document.getElementById('ef-pub').value=ep?(ep.publish||''):'';
  document.getElementById('ef-thumb').value=ep?(ep.thumb||''):'';
  document.getElementById('ef-links').value=ep?(ep.links||''):'';
  document.getElementById('ef-notes').value=ep?(ep.notes||''):'';
  document.getElementById('ef-id').value=editId||'';
  document.getElementById('ef-sid').value=sid;
  document.getElementById('mo-ep-title').textContent=ep?'Edit Episode':'New Episode';
  pt(ep?(ep.thumb||''):'','ef-tp');
  document.getElementById('mo-ep').classList.remove('hi');
}
function saveEp(){
  const title=document.getElementById('ef-title').value.trim();if(!title){document.getElementById('ef-title').focus();return;}
  const sid=document.getElementById('ef-sid').value;if(!episodes[sid])episodes[sid]=[];
  const editId=document.getElementById('ef-id').value;
  const entry={id:editId||('e'+Date.now()),num:parseInt(document.getElementById('ef-num').value)||episodes[sid].length+1,title,stage:document.getElementById('ef-stage').value,platforms:document.getElementById('ef-plats').value.trim(),record:document.getElementById('ef-rec').value,publish:document.getElementById('ef-pub').value,thumb:document.getElementById('ef-thumb').value.trim(),links:document.getElementById('ef-links').value.trim(),notes:document.getElementById('ef-notes').value.trim()};
  if(editId){const i=episodes[sid].findIndex(x=>x.id===editId);if(i>-1)episodes[sid][i]=entry;}
  else episodes[sid].push(entry);
  episodes[sid].sort((a,b)=>(a.num||0)-(b.num||0));
