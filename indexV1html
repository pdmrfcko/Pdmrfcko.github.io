  dv.innerHTML=`<button class="bk" onclick="closeSeriesDetail()">← All Series</button>
  <div class="dh"><div class="dtag" style="color:${col}">${s.persona.toUpperCase()} · ${s.platforms||''} · ${s.format||''}</div><div class="dname" style="color:${col}">${s.name}</div>
